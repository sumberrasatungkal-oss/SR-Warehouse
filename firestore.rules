rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isAdmin() { return isSignedIn() && userRole() == 'admin'; }
    function isSupervisor() { return isSignedIn() && userRole() == 'supervisor'; }
    function isStaff() { return isSignedIn() && userRole() == 'staff'; }
    function canEditItems() { return isAdmin() || isSupervisor(); }
    function canTransact() { return isAdmin() || isSupervisor() || isStaff(); }

    // Profil & role tiap user. Hanya admin yang boleh menulis,
    // tiap user hanya boleh membaca profilnya sendiri (admin boleh baca semua).
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin();
    }

    function isStockOnlyChange() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentStock', 'updatedAt']);
    }

    // Master data barang. Semua user login boleh baca.
    // Tambah: Admin, Supervisor, & Staff. Edit detail: Admin & Supervisor.
    // Staff boleh mengubah stok SAJA, sebagai efek dari transaksi (masuk/keluar/opname).
    // Hapus: Admin saja.
    match /items/{itemId} {
      allow read: if isSignedIn();
      allow create: if canEditItems() || isStaff();
      allow update: if canEditItems() || (canTransact() && isStockOnlyChange());
      allow delete: if isAdmin();
    }

    // Riwayat transaksi (masuk/keluar/opname). Tidak pernah benar-benar dihapus.
    // Update hanya boleh oleh Admin, dipakai khusus saat menyetujui
    // permintaan revisi/pembatalan (lihat correctionRequests di bawah).
    match /transactions/{txId} {
      allow read: if isSignedIn();
      allow create: if canTransact();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Permintaan revisi/pembatalan transaksi oleh staff/supervisor,
    // disetujui/ditolak oleh admin.
    match /correctionRequests/{reqId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.requestedBy == request.auth.uid);
      allow create: if canTransact() && request.resource.data.requestedBy == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Log aktivitas user, permanen. Hanya Admin yang boleh membaca.
    match /activityLogs/{logId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // Penanda kapan tiap user terakhir generate "laporan aktivitas pribadi".
    // Tiap user hanya boleh baca/tulis miliknya sendiri.
    match /userReportState/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }
  }
}
